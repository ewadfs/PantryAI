# Application
ENVIRONMENT=development
PORT=8000

# Database (async SQLAlchemy + asyncpg).
# A sync-style postgresql:// URL (e.g. from Railway) is auto-normalized to
# postgresql+asyncpg:// at runtime, so either scheme works here.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/pantryai

# Anthropic
ANTHROPIC_API_KEY=

# Supabase (auth)
SUPABASE_URL=
SUPABASE_JWT_SECRET=
SUPABASE_JWKS_URL=

# Cloudflare R2 (S3-compatible image storage).
# R2_ACCOUNT_ID is the full R2 endpoint URL:
#   https://<account>.r2.cloudflarestorage.com/<bucket>
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=

# Anthropic model selection.
# RECIPE_MODEL serves Stage 1 (concepts) — the creative step. It must stay a
# Sonnet-class model or better: pointing it at Haiku caused the Prompt 32
# quality regression (clone anchors, incoherent dishes, sub-floor macros).
# Only DETAIL_MODEL (Stage 2 details) and CRITIC_MODEL are Haiku-safe.
VISION_MODEL=claude-sonnet-4-6
RECIPE_MODEL=claude-sonnet-4-6
DETAIL_MODEL=claude-haiku-4-5
CRITIC_MODEL=claude-haiku-4-5

# Debug: LOG_PROMPTS=1 logs the fully-assembled Stage 1 prompt per generation
# (loud, contains pantry contents — audits only).
LOG_PROMPTS=0

# Flyer freshness: the in-app scheduler re-runs the circular pipeline every
# N hours (skips chain×regions whose fetch is still valid; advisory-locked so
# multi-replica deploys don't double-fetch). Generation also self-heals: a
# saved store with an empty deal cache triggers a background refresh.
DEALS_REFRESH_ENABLED=1
DEALS_REFRESH_HOURS=6

# Circular viewer (P37): flyer page images are the store's creative — flip
# this off to hide the viewer (endpoint 404s, clients hide entry points).
EXPOSE_CIRCULAR_VIEWER=1

# CORS (comma-separated origins; * allows all)
CORS_ORIGINS=*
